---
import { getCollection, getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import PricingTiers from "../../components/react/PricingTiers";
import PriceCalculator from "../../components/react/PriceCalculator";
import { SALES_EMAIL } from "../../lib/pricing";
import { useTranslations } from "../../i18n/utils";
import { type Lang } from "../../i18n/ui";

export function getStaticPaths() {
  return [{ params: { lang: "de" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

/* Texte kommen aus src/content/<collection>/<lang>/ (Markdown) */
const intro = await getEntry("texte", `${lang}/preise`);
const rechner = await getEntry("texte", `${lang}/preisrechner`);
const faqIntro = await getEntry("texte", `${lang}/faq`);
if (!intro || !rechner || !faqIntro) {
  throw new Error(`Fehlender Eintrag in src/content/texte/${lang}/`);
}

const { Content: IntroText } = await render(intro);
const { Content: RechnerText } = await render(rechner);

const faq = (await getCollection("faq"))
  .filter((e) => e.id.startsWith(`${lang}/`))
  .sort((a, b) => a.data.order - b.data.order);
const faqContents = await Promise.all(faq.map((f) => render(f)));
---

<BaseLayout lang={lang} title={t("metaPricingTitle")} description={t("metaPricingDesc")}>
  <!-- ===== Preisübersicht ===== -->
  <section class="relative overflow-hidden py-20 sm:py-24">
    <div
      class="pointer-events-none absolute -top-40 left-1/2 h-[400px] w-[700px] -translate-x-1/2 rounded-full bg-brand-100/50 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <p class="eyebrow">{t("pricingEyebrow")}</p>
        <h1 class="mt-3 text-4xl font-extrabold tracking-display text-gray-900 sm:text-5xl">
          {intro.data.title}
        </h1>
        <div class="mt-4 text-lg text-steel">
          <IntroText />
        </div>
      </div>

      <div class="mt-12">
        <PricingTiers client:visible lang={lang} />
      </div>
    </div>
  </section>

  <!-- ===== Preisrechner ===== -->
  <section id="preisrechner" class="scroll-mt-20 bg-gray-50 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="eyebrow">{t("calculatorEyebrow")}</p>
        <h2 class="mt-3 text-3xl font-bold tracking-display text-gray-900 sm:text-4xl">
          {rechner.data.title}
        </h2>
        <div class="mt-4 text-lg text-steel">
          <RechnerText />
        </div>
      </div>

      <div class="mt-12">
        <PriceCalculator client:visible lang={lang} />
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <p class="eyebrow reveal text-center">{t("faqEyebrow")}</p>
      <h2 class="reveal mt-3 text-center text-3xl font-bold tracking-display text-gray-900">
        {faqIntro.data.title}
      </h2>
      <div class="mt-10 space-y-4">
        {
          faq.map((item, i) => (
            <details class="reveal group rounded-2xl border border-gray-200 bg-white p-6">
              <summary class="flex cursor-pointer list-none items-center justify-between font-semibold text-gray-900">
                {item.data.question}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="h-5 w-5 shrink-0 text-steel transition-transform group-open:rotate-180"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <div class="mt-3 text-sm leading-relaxed text-steel">
                {(() => {
                  const FaqText = faqContents[i].Content;
                  return <FaqText />;
                })()}
              </div>
            </details>
          ))
        }
      </div>

      <p class="mt-10 text-center text-sm text-steel">
        {t("faqStillQuestions")}{" "}
        <a href={`mailto:${SALES_EMAIL}`} class="font-medium text-brand-600 hover:underline">
          {SALES_EMAIL}
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
