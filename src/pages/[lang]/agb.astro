---
import { getEntry, render } from "astro:content";
import BaseLayout from "../../layouts/BaseLayout.astro";
import Mermaid from "../../components/Mermaid.astro";
import { useTranslations } from "../../i18n/utils";
import { type Lang } from "../../i18n/ui";

export function getStaticPaths() {
  return [{ params: { lang: "de" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

/* Inhalt aus src/content/seiten/<lang>/agb.md */
const seite = await getEntry("seiten", `${lang}/agb`);
if (!seite) throw new Error(`src/content/seiten/${lang}/agb.md fehlt`);
const { Content } = await render(seite);
---

<BaseLayout lang={lang} title={`${seite.data.title} – ${t("titleSuffix")}`}>
  <section class="mx-auto max-w-3xl px-4 py-20 sm:px-6">
    <h1 class="text-3xl font-bold tracking-display text-gray-900">
      {seite.data.title}
    </h1>
    <div class="prose prose-gray mt-8">
      <Content />
    </div>
  </section>
  <Mermaid />
</BaseLayout>
