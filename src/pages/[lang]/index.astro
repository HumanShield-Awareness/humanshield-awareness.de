---
import { getCollection, getEntry, render } from "astro:content";
import { Image } from "astro:assets";
import BaseLayout from "../../layouts/BaseLayout.astro";
import { GITHUB_REPO_URL } from "../../lib/pricing";
import { useTranslations, localizedPath } from "../../i18n/utils";
import { type Lang } from "../../i18n/ui";
import heroShot from "../../assets/landingpage-1.png";

export function getStaticPaths() {
  return [{ params: { lang: "de" } }, { params: { lang: "en" } }];
}

const lang = Astro.params.lang as Lang;
const t = useTranslations(lang);

/* Texte kommen aus src/content/<collection>/<lang>/ (Markdown) */
const hero = await getEntry("texte", `${lang}/hero`);
const funktionen = await getEntry("texte", `${lang}/funktionen`);
const soFunktionierts = await getEntry("texte", `${lang}/so-funktionierts`);
const vertrauenIntro = await getEntry("texte", `${lang}/vertrauen`);
const openCore = await getEntry("texte", `${lang}/open-core`);
const cta = await getEntry("texte", `${lang}/cta`);
if (!hero || !funktionen || !soFunktionierts || !vertrauenIntro || !openCore || !cta) {
  throw new Error(`Fehlender Eintrag in src/content/texte/${lang}/`);
}

const { Content: HeroText } = await render(hero);
const { Content: FunktionenText } = await render(funktionen);
const { Content: VertrauenText } = await render(vertrauenIntro);
const { Content: OpenCoreText } = await render(openCore);
const { Content: CtaText } = await render(cta);

const vertrauen = (await getCollection("vertrauen"))
  .filter((e) => e.id.startsWith(`${lang}/`))
  .sort((a, b) => a.data.order - b.data.order);
const vertrauenContents = await Promise.all(vertrauen.map((v) => render(v)));

const features = (await getCollection("features"))
  .filter((e) => e.id.startsWith(`${lang}/`))
  .sort((a, b) => a.data.order - b.data.order);
const featureContents = await Promise.all(features.map((f) => render(f)));

const steps = (await getCollection("steps"))
  .filter((e) => e.id.startsWith(`${lang}/`))
  .sort((a, b) => a.data.order - b.data.order);
const stepContents = await Promise.all(steps.map((s) => render(s)));

/* Icon-Map für Feature-Karten – Namen siehe src/content.config.ts */
const icons: Record<string, string> = {
  mail: "M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75",
  "academic-cap":
    "M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342",
  "chart-bar":
    "M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z",
  "shield-check":
    "M12 2.25c.223 0 .445.043.652.127l6.75 2.7a1.125 1.125 0 0 1 .698 1.043v5.13c0 4.661-2.905 8.585-7.17 10.264a1.125 1.125 0 0 1-.86 0C7.155 19.84 4.25 15.915 4.25 11.25V6.12c0-.46.28-.874.698-1.043l6.75-2.7c.207-.084.43-.127.652-.127Z",
  "code-bracket":
    "M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5",
  "lock-closed":
    "M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z",
  "map-pin":
    "M15 10.5a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z M19.5 10.5c0 7.142-7.5 11.25-7.5 11.25S4.5 17.642 4.5 10.5a7.5 7.5 0 1 1 15 0Z",
  "document-check":
    "M10.125 2.25h-4.5c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125v-9M10.125 2.25h.375a9 9 0 0 1 9 9v.375M10.125 2.25A3.375 3.375 0 0 1 13.5 5.625v1.5c0 .621.504 1.125 1.125 1.125h1.5a3.375 3.375 0 0 1 3.375 3.375M9 15l2.25 2.25L15 12",
};
---

<BaseLayout lang={lang} title={t("metaHomeTitle")} description={t("metaDefaultDesc")}>
  <!-- ===== Hero ===== -->
  <section class="relative overflow-hidden">
    <!-- Dezente Farbverläufe im Hintergrund -->
    <div
      class="pointer-events-none absolute -top-40 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-brand-100/60 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute -right-40 top-40 h-[300px] w-[400px] rounded-full bg-brand-100/40 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="relative mx-auto max-w-6xl px-4 pb-20 pt-16 sm:px-6 lg:pb-28 lg:pt-24">
      <div class="grid items-center gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Textspalte -->
        <div class="text-center lg:text-left">
          <div class="inline-flex items-center gap-2">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="3"
              class="h-4 w-4 text-brand-400"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="m4.5 12.75 6 6 9-13.5"></path>
            </svg>
            <span class="eyebrow">{t("heroEyebrow")}</span>
          </div>

          <h1
            class="mx-auto mt-6 max-w-xl text-4xl font-extrabold tracking-display text-gray-900 sm:text-5xl lg:mx-0 lg:text-6xl"
          >
            {hero.data.title}
            <span class="gradient-text">{hero.data.titleHighlight}</span>
          </h1>

          <div class="mx-auto mt-6 max-w-xl text-lg text-steel lg:mx-0">
            <HeroText />
          </div>

          <div
            class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row lg:justify-start"
          >
            <a
              href={localizedPath(lang, "/preise")}
              class="w-full rounded-full bg-brand-500 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-500/25 transition-all hover:bg-brand-600 hover:shadow-xl hover:shadow-brand-500/30 sm:w-auto"
            >
              {hero.data.ctaPrimary}
            </a>
            <a
              href={GITHUB_REPO_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="w-full rounded-full border border-gray-300 bg-white px-8 py-3.5 text-base font-semibold text-gray-800 transition-colors hover:border-brand-500 hover:bg-gray-50 sm:w-auto"
            >
              {hero.data.ctaSecondary}
            </a>
          </div>

          <p class="mt-6 text-sm text-steel">{hero.data.note}</p>
        </div>

        <!-- Screenshot-Banner (Produkt-Control-Center) -->
        <div class="relative">
          <div
            class="pointer-events-none absolute -inset-4 -z-10 rounded-[32px] bg-brand-500/10 blur-2xl"
            aria-hidden="true"
          >
          </div>
          <div
            class="overflow-hidden rounded-2xl border border-gray-100 bg-white shadow-xl"
          >
            <!-- Angedeuteter Browser-Rahmen -->
            <div
              class="flex items-center gap-2 border-b border-gray-100 bg-gray-50 px-4 py-2.5"
            >
              <span class="h-2.5 w-2.5 rounded-full bg-gray-300"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-gray-300"></span>
              <span class="h-2.5 w-2.5 rounded-full bg-gray-300"></span>
              <span
                class="ml-2 hidden flex-1 items-center gap-1.5 rounded-full bg-gray-100 px-3 py-1 text-xs text-gray-400 sm:flex"
              >
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  class="h-3 w-3"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d="M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z"
                  ></path>
                </svg>
                <span class="metric">humanshield.app</span>
              </span>
            </div>
            <Image
              src={heroShot}
              alt={t("heroImageAlt")}
              widths={[560, 900, 1400, 1788]}
              sizes="(min-width: 1024px) 45vw, 100vw"
              loading="eager"
              class="h-auto w-full"
            />
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ===== Features ===== -->
  <section id="funktionen" class="scroll-mt-20 bg-gray-50 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="eyebrow">{t("featuresEyebrow")}</p>
        <h2 class="mt-3 text-3xl font-bold tracking-display text-gray-900 sm:text-4xl">
          {funktionen.data.title}
        </h2>
        <div class="mt-4 text-lg text-steel">
          <FunktionenText />
        </div>
      </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map((f, i) => (
            <div
              class={`reveal reveal-delay-${(i % 3) + 1} rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg`}
            >
              <span class="icon-chip flex h-11 w-11 items-center justify-center rounded-xl text-brand-400">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="h-6 w-6"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d={icons[f.data.icon]}
                  />
                </svg>
              </span>
              <h3 class="mt-4 text-lg font-semibold text-gray-900">{f.data.title}</h3>
              <div class="mt-2 text-sm leading-relaxed text-steel">
                {(() => {
                  const FeatureText = featureContents[i].Content;
                  return <FeatureText />;
                })()}
              </div>
            </div>
          ))
        }
      </div>

      <div class="reveal mt-12 text-center">
        <a
          href={localizedPath(lang, "/funktionen")}
          class="inline-flex items-center gap-2 rounded-full border border-gray-300 bg-white px-6 py-3 text-sm font-semibold text-gray-800 transition-colors hover:border-brand-500 hover:bg-gray-50"
        >
          {t("homeSeeAllFeatures")}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== So funktioniert's ===== -->
  <section id="so-funktionierts" class="scroll-mt-20 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="eyebrow">{t("howEyebrow")}</p>
        <h2 class="mt-3 text-3xl font-bold tracking-display text-gray-900 sm:text-4xl">
          {soFunktionierts.data.title}
        </h2>
      </div>

      <div class="mt-14 grid gap-8 md:grid-cols-3">
        {
          steps.map((s, i) => (
            <div class={`reveal reveal-delay-${i + 1} relative rounded-2xl border border-gray-100 p-6`}>
              <span class="metric text-4xl font-bold text-brand-200">
                {String(s.data.order).padStart(2, "0")}
              </span>
              <h3 class="mt-3 text-lg font-semibold text-gray-900">{s.data.title}</h3>
              <div class="mt-2 text-sm leading-relaxed text-steel">
                {(() => {
                  const StepText = stepContents[i].Content;
                  return <StepText />;
                })()}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== Vertrauen: Made in Germany / DSGVO / NIS2 ===== -->
  <section id="compliance" class="scroll-mt-20 bg-gray-50 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="reveal mx-auto max-w-2xl text-center">
        <p class="eyebrow">{t("complianceEyebrow")}</p>
        <h2 class="mt-3 text-3xl font-bold tracking-display text-gray-900 sm:text-4xl">
          {vertrauenIntro.data.title}
        </h2>
        <div class="mt-4 text-lg text-steel">
          <VertrauenText />
        </div>
      </div>

      <div class="mt-14 grid gap-6 md:grid-cols-3">
        {
          vertrauen.map((v, i) => (
            <div
              class={`reveal reveal-delay-${i + 1} rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg`}
            >
              <span class="icon-chip flex h-11 w-11 items-center justify-center rounded-xl text-brand-400">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="h-6 w-6"
                  aria-hidden="true"
                >
                  <path
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    d={icons[v.data.icon]}
                  />
                </svg>
              </span>
              <h3 class="mt-4 text-lg font-semibold text-gray-900">{v.data.title}</h3>
              <div class="mt-2 text-sm leading-relaxed text-steel">
                {(() => {
                  const VertrauenCardText = vertrauenContents[i].Content;
                  return <VertrauenCardText />;
                })()}
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== Open Core ===== -->
  <!-- Design-System-Dunkelscope (.hs-dark) = warmes Near-Black + warme Textrampe -->
  <section class="hs-dark py-20 sm:py-24" style="background: var(--bg-page)">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="reveal mx-auto flex max-w-3xl flex-col items-center text-center">
        <p class="eyebrow" style="color:var(--ember-400)">{t("openCoreEyebrow")}</p>
        <h2
          class="mt-3 text-3xl font-bold tracking-display sm:text-4xl"
          style="color: var(--text-primary)"
        >
          {openCore.data.title}
        </h2>
        <div class="mt-4 text-lg" style="color: var(--text-secondary)">
          <OpenCoreText />
        </div>
        <a
          href={GITHUB_REPO_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-semibold text-gray-900 transition-colors hover:bg-gray-200"
        >
          {openCore.data.ctaPrimary}
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div
        class="reveal relative overflow-hidden rounded-[28px] px-6 py-16 text-center sm:px-16"
        style="background: var(--gradient-ember)"
      >
        <div
          class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-white/10 blur-2xl"
          aria-hidden="true"
        >
        </div>
        <h2 class="text-3xl font-bold tracking-display text-white sm:text-4xl">
          {cta.data.title}
        </h2>
        <div class="mx-auto mt-4 max-w-xl text-lg text-brand-100">
          <CtaText />
        </div>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href={localizedPath(lang, "/preise#preisrechner")}
            class="w-full rounded-full bg-white px-8 py-3.5 text-base font-semibold text-brand-600 transition-colors hover:bg-brand-50 sm:w-auto"
          >
            {cta.data.ctaPrimary}
          </a>
          <a
            href={localizedPath(lang, "/preise")}
            class="w-full rounded-full border border-white/40 px-8 py-3.5 text-base font-semibold text-white transition-colors hover:bg-white/10 sm:w-auto"
          >
            {cta.data.ctaSecondary}
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
