---
import { getEntry, render } from "astro:content";
import BaseLayout from "../layouts/BaseLayout.astro";

/* Inhalt aus src/content/seiten/datenschutz.md */
const seite = await getEntry("seiten", "datenschutz");
if (!seite) throw new Error("src/content/seiten/datenschutz.md fehlt");
const { Content } = await render(seite);
---

<BaseLayout title={`${seite.data.title} – HumanShield Awareness`}>
  <section class="mx-auto max-w-3xl px-4 py-20 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">
      {seite.data.title}
    </h1>
    <div class="prose prose-gray mt-8">
      <Content />
    </div>
  </section>
</BaseLayout>
