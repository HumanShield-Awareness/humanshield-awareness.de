---
import BaseLayout from "../layouts/BaseLayout.astro";
import PricingTiers from "../components/react/PricingTiers";
import PriceCalculator from "../components/react/PriceCalculator";
import { SALES_EMAIL } from "../lib/pricing";

const faq = [
  {
    q: "Wie funktioniert die Abrechnung?",
    a: "Business und Enterprise sind Jahresabos. Die Zahlung läuft vollständig über Paddle als Merchant of Record – inklusive Rechnung und korrekter Umsatzsteuer für Ihr Land.",
  },
  {
    q: "Brauche ich ein Kundenkonto?",
    a: "Nein. Rechnungen und Abo-Verwaltung laufen über das Paddle-Kundenportal, den Link erhalten Sie mit Ihrer Bestellbestätigung per E-Mail.",
  },
  {
    q: "Wie erhalte ich meine Lizenz?",
    a: "Nach dem Kauf wird Ihre Lizenz automatisch erzeugt und per E-Mail zugestellt. Sie ist signiert und offline validierbar – Ihre Installation braucht keine Verbindung zu unseren Servern.",
  },
  {
    q: "Was passiert bei einer Kündigung?",
    a: "Ihre Lizenz bleibt bis zum Ende des bezahlten Jahres gültig und läuft dann einfach aus. Es wird nichts aktiv gesperrt.",
  },
];
---

<BaseLayout
  title="Preise – HumanShield Awareness"
  description="Transparente Preise für HumanShield Awareness: kostenlose Community-Edition, Business-Jahresabo pro Mitarbeiter:in und individuelle Enterprise-Angebote."
>
  <!-- ===== Preisübersicht ===== -->
  <section class="relative overflow-hidden py-20 sm:py-24">
    <div
      class="pointer-events-none absolute -top-40 left-1/2 h-[400px] w-[700px] -translate-x-1/2 rounded-full bg-brand-100/50 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="relative mx-auto max-w-6xl px-4 sm:px-6">
      <div class="mx-auto max-w-2xl text-center">
        <h1 class="text-4xl font-extrabold tracking-tight text-gray-900 sm:text-5xl">
          Transparente Preise
        </h1>
        <p class="mt-4 text-lg text-steel">
          Kostenlos starten mit Community – oder volle Power mit Business und
          Enterprise im Jahresabo.
        </p>
      </div>

      <div class="mt-12">
        <PricingTiers client:visible />
      </div>
    </div>
  </section>

  <!-- ===== Preisrechner ===== -->
  <section id="preisrechner" class="scroll-mt-20 bg-gray-50 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="reveal mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Was kostet HumanShield für Ihr Team?
        </h2>
        <p class="mt-4 text-lg text-steel">
          Mitarbeiterzahl wählen – Ihren Preis sehen Sie sofort.
        </p>
      </div>

      <div class="mt-12">
        <PriceCalculator client:visible />
      </div>
    </div>
  </section>

  <!-- ===== FAQ ===== -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-3xl px-4 sm:px-6">
      <h2 class="reveal text-center text-3xl font-bold tracking-tight text-gray-900">
        Häufige Fragen
      </h2>
      <div class="mt-10 space-y-4">
        {
          faq.map((item) => (
            <details class="reveal group rounded-2xl border border-gray-200 bg-white p-6">
              <summary class="flex cursor-pointer list-none items-center justify-between font-semibold text-gray-900">
                {item.q}
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="2"
                  stroke="currentColor"
                  class="h-5 w-5 shrink-0 text-steel transition-transform group-open:rotate-180"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d="m19.5 8.25-7.5 7.5-7.5-7.5" />
                </svg>
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-steel">{item.a}</p>
            </details>
          ))
        }
      </div>

      <p class="mt-10 text-center text-sm text-steel">
        Noch Fragen? Schreiben Sie uns an{" "}
        <a href={`mailto:${SALES_EMAIL}`} class="font-medium text-brand-600 hover:underline">
          {SALES_EMAIL}
        </a>
      </p>
    </div>
  </section>
</BaseLayout>
