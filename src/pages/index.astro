---
/**
 * Sprach-Weiche für die Root-URL "/". Rein statisch (Cloudflare Pages):
 * per Client-JS anhand der Browsersprache auf /de/ oder /en/ umleiten.
 * Ohne JS greift der <noscript>-Meta-Refresh auf die Standardsprache (DE).
 */
import { defaultLang, languages, type Lang } from "../i18n/ui";

const langCodes = Object.keys(languages) as Lang[];
---

<!doctype html>
<html lang={defaultLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="robots" content="noindex" />
    <title>SentryMail</title>
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    {
      langCodes.map((code) => (
        <link rel="alternate" hreflang={code} href={new URL(`/${code}/`, Astro.site)} />
      ))
    }
    <link
      rel="alternate"
      hreflang="x-default"
      href={new URL(`/${defaultLang}/`, Astro.site)}
    />
    <script is:inline>
      (function () {
        var supported = ["de", "en"];
        var pref = (navigator.language || "de").slice(0, 2).toLowerCase();
        var target = supported.indexOf(pref) !== -1 ? pref : "de";
        window.location.replace("/" + target + "/");
      })();
    </script>
    <noscript>
      <meta http-equiv="refresh" content={`0; url=/${defaultLang}/`} />
    </noscript>
  </head>
  <body style="font-family: system-ui, sans-serif; text-align: center; padding: 3rem 1rem;">
    <p>Redirecting … / Weiterleitung …</p>
    <p>
      {
        langCodes.map((code, i) => (
          <>
            {i > 0 && " · "}
            <a href={`/${code}/`}>{languages[code]}</a>
          </>
        ))
      }
    </p>
  </body>
</html>
