---
import BaseLayout from "../layouts/BaseLayout.astro";
import { GITHUB_REPO_URL } from "../lib/pricing";

const features = [
  {
    title: "Phishing-Simulationen",
    text: "Realistische, anpassbare Kampagnen zeigen Ihren Mitarbeitenden, wie aktuelle Angriffe wirklich aussehen – ohne echtes Risiko.",
    icon: "M21.75 6.75v10.5a2.25 2.25 0 0 1-2.25 2.25h-15a2.25 2.25 0 0 1-2.25-2.25V6.75m19.5 0A2.25 2.25 0 0 0 19.5 4.5h-15a2.25 2.25 0 0 0-2.25 2.25m19.5 0v.243a2.25 2.25 0 0 1-1.07 1.916l-7.5 4.615a2.25 2.25 0 0 1-2.36 0L3.32 8.91a2.25 2.25 0 0 1-1.07-1.916V6.75",
  },
  {
    title: "Trainings, die hängen bleiben",
    text: "Kurze, interaktive Lerneinheiten statt stundenlanger Pflichtvideos – direkt in den Arbeitsalltag integrierbar.",
    icon: "M4.26 10.147a60.438 60.438 0 0 0-.491 6.347A48.62 48.62 0 0 1 12 20.904a48.62 48.62 0 0 1 8.232-4.41 60.46 60.46 0 0 0-.491-6.347m-15.482 0a50.636 50.636 0 0 0-2.658-.813A59.906 59.906 0 0 1 12 3.493a59.903 59.903 0 0 1 10.399 5.84c-.896.248-1.783.52-2.658.814m-15.482 0A50.717 50.717 0 0 1 12 13.489a50.702 50.702 0 0 1 7.74-3.342",
  },
  {
    title: "Reporting & Metriken",
    text: "Klickraten, Meldequoten und Lernfortschritt auf einen Blick – belegen Sie den Erfolg Ihres Awareness-Programms.",
    icon: "M3 13.125C3 12.504 3.504 12 4.125 12h2.25c.621 0 1.125.504 1.125 1.125v6.75C7.5 20.496 6.996 21 6.375 21h-2.25A1.125 1.125 0 0 1 3 19.875v-6.75ZM9.75 8.625c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125v11.25c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V8.625ZM16.5 4.125c0-.621.504-1.125 1.125-1.125h2.25C20.496 3 21 3.504 21 4.125v15.75c0 .621-.504 1.125-1.125 1.125h-2.25a1.125 1.125 0 0 1-1.125-1.125V4.125Z",
  },
  {
    title: "Datenschutz zuerst",
    text: "Entwickelt für den europäischen Markt: DSGVO-konform, datensparsam und auf Wunsch komplett selbst gehostet.",
    icon: "M12 2.25c.223 0 .445.043.652.127l6.75 2.7a1.125 1.125 0 0 1 .698 1.043v5.13c0 4.661-2.905 8.585-7.17 10.264a1.125 1.125 0 0 1-.86 0C7.155 19.84 4.25 15.915 4.25 11.25V6.12c0-.46.28-.874.698-1.043l6.75-2.7c.207-.084.43-.127.652-.127Z",
  },
  {
    title: "Open Core",
    text: "Der Kern von HumanShield ist Open Source. Prüfen Sie den Code, hosten Sie selbst – oder starten Sie direkt mit Business.",
    icon: "M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5",
  },
  {
    title: "Offline-Lizenzen",
    text: "Lizenzen sind signiert und offline validierbar – keine ständige Verbindung zu einem Lizenzserver nötig.",
    icon: "M16.5 10.5V6.75a4.5 4.5 0 1 0-9 0v3.75m-.75 11.25h10.5a2.25 2.25 0 0 0 2.25-2.25v-6.75a2.25 2.25 0 0 0-2.25-2.25H6.75a2.25 2.25 0 0 0-2.25 2.25v6.75a2.25 2.25 0 0 0 2.25 2.25Z",
  },
];

const steps = [
  {
    step: "01",
    title: "Kampagne aufsetzen",
    text: "Wählen Sie Vorlagen für Phishing-Simulationen und Trainings aus – in wenigen Minuten startklar.",
  },
  {
    step: "02",
    title: "Team trainieren",
    text: "Mitarbeitende erleben realistische Angriffe, lernen aus Fehlern und melden verdächtige Mails souverän.",
  },
  {
    step: "03",
    title: "Fortschritt messen",
    text: "Dashboards zeigen, wie Klickraten sinken und Meldequoten steigen – messbare Sicherheit statt Bauchgefühl.",
  },
];
---

<BaseLayout title="HumanShield Awareness – Security Awareness, die wirkt">
  <!-- ===== Hero ===== -->
  <section class="relative overflow-hidden">
    <!-- Dezente Farbverläufe im Hintergrund -->
    <div
      class="pointer-events-none absolute -top-40 left-1/2 h-[500px] w-[800px] -translate-x-1/2 rounded-full bg-brand-100/60 blur-3xl"
      aria-hidden="true"
    >
    </div>
    <div
      class="pointer-events-none absolute -right-40 top-40 h-[300px] w-[400px] rounded-full bg-orange-50 blur-3xl"
      aria-hidden="true"
    >
    </div>

    <div class="relative mx-auto max-w-6xl px-4 pb-24 pt-20 text-center sm:px-6 sm:pt-28">
      <a
        href={GITHUB_REPO_URL}
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center gap-2 rounded-full border border-brand-200 bg-brand-50 px-4 py-1.5 text-sm font-medium text-brand-700 transition-colors hover:border-brand-300"
      >
        <span class="h-2 w-2 rounded-full bg-brand-500"></span>
        Open Core – der Kern ist Open Source
      </a>

      <h1
        class="mx-auto mt-6 max-w-3xl text-4xl font-extrabold tracking-tight text-gray-900 sm:text-6xl"
      >
        Security Awareness, die Ihr Team
        <span class="text-brand-500">wirklich schützt</span>
      </h1>

      <p class="mx-auto mt-6 max-w-2xl text-lg text-steel">
        HumanShield macht Ihre Mitarbeitenden zur stärksten Verteidigungslinie:
        realistische Phishing-Simulationen, Trainings mit Aha-Effekt und
        Reporting, das Fortschritt sichtbar macht.
      </p>

      <div class="mt-10 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href="/preise"
          class="w-full rounded-full bg-brand-500 px-8 py-3.5 text-base font-semibold text-white shadow-lg shadow-brand-500/25 transition-all hover:bg-brand-600 hover:shadow-xl hover:shadow-brand-500/30 sm:w-auto"
        >
          Preise ansehen
        </a>
        <a
          href={GITHUB_REPO_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="w-full rounded-full border border-gray-300 bg-white px-8 py-3.5 text-base font-semibold text-gray-800 transition-colors hover:border-gray-400 hover:bg-gray-50 sm:w-auto"
        >
          Auf GitHub ansehen
        </a>
      </div>

      <p class="mt-6 text-sm text-steel">
        Jahresabo über Paddle · Rechnung &amp; VAT inklusive · kein Kundenkonto nötig
      </p>
    </div>
  </section>

  <!-- ===== Features ===== -->
  <section id="funktionen" class="scroll-mt-20 bg-gray-50 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="reveal mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          Alles für ein wirksames Awareness-Programm
        </h2>
        <p class="mt-4 text-lg text-steel">
          Vom ersten simulierten Angriff bis zum messbaren Kulturwandel – ohne
          Ballast, ohne Overhead.
        </p>
      </div>

      <div class="mt-14 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {
          features.map((f, i) => (
            <div
              class={`reveal reveal-delay-${(i % 3) + 1} rounded-2xl border border-gray-100 bg-white p-6 shadow-sm transition-all hover:-translate-y-1 hover:shadow-lg`}
            >
              <span class="flex h-11 w-11 items-center justify-center rounded-xl bg-brand-50 text-brand-500">
                <svg
                  xmlns="http://www.w3.org/2000/svg"
                  fill="none"
                  viewBox="0 0 24 24"
                  stroke-width="1.6"
                  stroke="currentColor"
                  class="h-6 w-6"
                  aria-hidden="true"
                >
                  <path stroke-linecap="round" stroke-linejoin="round" d={f.icon} />
                </svg>
              </span>
              <h3 class="mt-4 text-lg font-semibold text-gray-900">{f.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-steel">{f.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== So funktioniert's ===== -->
  <section id="so-funktionierts" class="scroll-mt-20 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="reveal mx-auto max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight text-gray-900 sm:text-4xl">
          In drei Schritten zu mehr Sicherheit
        </h2>
      </div>

      <div class="mt-14 grid gap-8 md:grid-cols-3">
        {
          steps.map((s, i) => (
            <div class={`reveal reveal-delay-${i + 1} relative rounded-2xl border border-gray-100 p-6`}>
              <span class="text-4xl font-extrabold text-brand-200">{s.step}</span>
              <h3 class="mt-3 text-lg font-semibold text-gray-900">{s.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-steel">{s.text}</p>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- ===== Open Core ===== -->
  <section class="bg-gray-900 py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div class="reveal mx-auto flex max-w-3xl flex-col items-center text-center">
        <span
          class="inline-flex items-center gap-2 rounded-full border border-gray-700 bg-gray-800 px-4 py-1.5 text-sm font-medium text-gray-300"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="1.6"
            stroke="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path
              stroke-linecap="round"
              stroke-linejoin="round"
              d="M17.25 6.75 22.5 12l-5.25 5.25m-10.5 0L1.5 12l5.25-5.25m7.5-3-4.5 16.5"
            ></path>
          </svg>
          Open Core
        </span>
        <h2 class="mt-6 text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Vertrauen beginnt mit offenem Code
        </h2>
        <p class="mt-4 text-lg text-gray-400">
          Der Kern von HumanShield ist Open Source und kann kostenlos selbst
          gehostet werden. Business und Enterprise ergänzen den Kern um
          Funktionen für den professionellen Einsatz – fair lizenziert als
          Jahresabo.
        </p>
        <a
          href={GITHUB_REPO_URL}
          target="_blank"
          rel="noopener noreferrer"
          class="mt-8 inline-flex items-center gap-2 rounded-full bg-white px-6 py-3 text-sm font-semibold text-gray-900 transition-colors hover:bg-gray-200"
        >
          Zum GitHub-Repository
          <svg
            xmlns="http://www.w3.org/2000/svg"
            fill="none"
            viewBox="0 0 24 24"
            stroke-width="2"
            stroke="currentColor"
            class="h-4 w-4"
            aria-hidden="true"
          >
            <path stroke-linecap="round" stroke-linejoin="round" d="M13.5 4.5 21 12l-7.5 7.5M21 12H3"></path>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- ===== CTA ===== -->
  <section class="py-20 sm:py-24">
    <div class="mx-auto max-w-6xl px-4 sm:px-6">
      <div
        class="reveal relative overflow-hidden rounded-3xl bg-brand-500 px-6 py-16 text-center sm:px-16"
      >
        <div
          class="pointer-events-none absolute -right-20 -top-20 h-64 w-64 rounded-full bg-white/10 blur-2xl"
          aria-hidden="true"
        >
        </div>
        <h2 class="text-3xl font-bold tracking-tight text-white sm:text-4xl">
          Bereit, Ihr Team zu stärken?
        </h2>
        <p class="mx-auto mt-4 max-w-xl text-lg text-brand-100">
          Berechnen Sie in Sekunden Ihren Preis – oder starten Sie kostenlos
          mit der Community-Edition.
        </p>
        <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
          <a
            href="/preise#preisrechner"
            class="w-full rounded-full bg-white px-8 py-3.5 text-base font-semibold text-brand-600 transition-colors hover:bg-brand-50 sm:w-auto"
          >
            Preis berechnen
          </a>
          <a
            href="/preise"
            class="w-full rounded-full border border-white/40 px-8 py-3.5 text-base font-semibold text-white transition-colors hover:bg-white/10 sm:w-auto"
          >
            Preise vergleichen
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
