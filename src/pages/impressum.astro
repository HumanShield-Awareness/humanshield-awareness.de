---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Impressum – HumanShield Awareness">
  <section class="mx-auto max-w-3xl px-4 py-20 sm:px-6">
    <h1 class="text-3xl font-bold tracking-tight text-gray-900">Impressum</h1>
    <div class="prose mt-8 text-steel">
      <!-- TODO: Vollständiges Impressum gemäß § 5 DDG ergänzen -->
      <p><strong>Angaben gemäß § 5 DDG</strong></p>
      <p>
        [Name / Firma]<br />
        [Straße und Hausnummer]<br />
        [PLZ und Ort]
      </p>
      <p>
        E-Mail: support@secure-bits.org
      </p>
    </div>
  </section>
</BaseLayout>
