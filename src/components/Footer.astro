---
import { GITHUB_REPO_URL, SALES_EMAIL } from "../lib/pricing";
import { useTranslations, localizedPath, format } from "../i18n/utils";
import { type Lang } from "../i18n/ui";

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = useTranslations(lang);

const year = new Date().getFullYear();

/**
 * TODO: Sobald das Paddle-Kundenportal eingerichtet ist, die von Paddle
 * bereitgestellte Portal-URL hier eintragen (Konvention aus CLAUDE.md).
 */
const PADDLE_PORTAL_URL = "#";
---

<footer class="border-t border-gray-100 bg-gray-50">
  <div class="mx-auto max-w-6xl px-4 py-12 sm:px-6">
    <div class="grid gap-10 sm:grid-cols-2 lg:grid-cols-4">
      <div>
        <a
          href={localizedPath(lang, "/")}
          class="text-lg font-bold lowercase text-gray-900"
          style="letter-spacing:-0.04em"
          aria-label="humanshield."
        >
          humanshield<span class="text-brand-500">.</span>
        </a>
        <p class="mt-3 text-sm text-steel">
          {t("footerTagline")}
        </p>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-gray-900">{t("footerProduct")}</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href={localizedPath(lang, "/funktionen")} class="text-steel hover:text-gray-900">{t("navFeatures")}</a></li>
          <li><a href={localizedPath(lang, "/preise")} class="text-steel hover:text-gray-900">{t("navPricing")}</a></li>
          <li><a href={localizedPath(lang, "/preise#preisrechner")} class="text-steel hover:text-gray-900">{t("navCalculator")}</a></li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-gray-900">{t("footerResources")}</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li>
            <a
              href={GITHUB_REPO_URL}
              target="_blank"
              rel="noopener noreferrer"
              class="text-steel hover:text-gray-900">{t("footerGithubOpenCore")}</a
            >
          </li>
          <li>
            <a href={PADDLE_PORTAL_URL} class="text-steel hover:text-gray-900"
              >{t("footerManageBilling")}</a
            >
          </li>
          <li>
            <a href={`mailto:${SALES_EMAIL}`} class="text-steel hover:text-gray-900"
              >{t("footerContact")}</a
            >
          </li>
        </ul>
      </div>

      <div>
        <h3 class="text-sm font-semibold text-gray-900">{t("footerLegal")}</h3>
        <ul class="mt-3 space-y-2 text-sm">
          <li><a href={localizedPath(lang, "/impressum")} class="text-steel hover:text-gray-900">{t("footerImprint")}</a></li>
          <li><a href={localizedPath(lang, "/datenschutz")} class="text-steel hover:text-gray-900">{t("footerPrivacy")}</a></li>
        </ul>
      </div>
    </div>

    <div
      class="mt-10 flex flex-col items-center justify-between gap-4 border-t border-gray-200 pt-6 text-sm text-steel sm:flex-row"
    >
      <p>© {format("{year} HumanShield Awareness. {rights}", { year, rights: t("footerRights") })}</p>
      <p>
        {t("footerPaddlePrefix")}
        <a
          href="https://www.paddle.com"
          target="_blank"
          rel="noopener noreferrer"
          class="underline hover:text-gray-900">Paddle</a
        > {t("footerPaddleSuffix")}
      </p>
    </div>
  </div>
</footer>
