{
  // Cloudflare-Pages-Konfiguration: statisches Build-Output-Verzeichnis.
  // Deploy läuft über das Pages-Projekt (Git-Integration), diese Datei
  // hält die Config im Repo konsistent und erlaubt `wrangler pages deploy`.
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "humanshield-awareness-de",
  "pages_build_output_dir": "./dist"
}
