# Paddle-Konfiguration (öffentlicher Client-Token – KEIN Secret-Key).
# Diese PUBLIC_-Variablen werden zur BUILD-ZEIT ins Client-Bundle eingebettet
# (import.meta.env). In Produktion in Cloudflare Pages → Settings →
# Environment variables hinterlegen; nach Änderung ist ein Redeploy nötig.

# Client-Side-Token aus dem Paddle-Dashboard (Developer Tools → Authentication).
# Sandbox-Token beginnen mit "test_", Live-Token mit "live_".
PUBLIC_PADDLE_CLIENT_TOKEN=test_xxxxxxxxxxxxxxxxxxxxxxxx

# "sandbox" zum Testen, "production" für den Echtbetrieb (Default: sandbox).
PUBLIC_PADDLE_ENVIRONMENT=sandbox
